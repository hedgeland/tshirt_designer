    style Ideation fill:#d1e7dd,stroke:#198754
    style PromptBuild fill:#d1ecf1,stroke:#0dcaf0
    style Variants fill:#cfe2ff,stroke:#0d6efd
    style Finalize fill:#e2d9f3,stroke:#6f42c1
